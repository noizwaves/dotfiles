{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(head:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Read(~/.claude/*)",
      "Read(.claude/*)"
    ],
    "defaultMode": "plan"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "statusLine": {
    "type": "command",
    "command": "~/.local/bin/starship-claude"
  }
}
