{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(head:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Read(~/.claude/*)",
      "Read(.claude/*)",
      "Bash(python-safe *)"
    ],
    "defaultMode": "plan"
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@latest --style=powerline"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "model": "opus"
}
