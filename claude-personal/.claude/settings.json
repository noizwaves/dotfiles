{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(head:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Read(~/.claude/*)",
      "Read(.claude/*)",
      "Read(~/workspace/**)",
      "Bash(ls -al *)",
      "Bash(python-safe *)",
      "WebFetch(domain:buildkite.com)",
      "Bash(bk agent list *)",
      "Bash(bk agent view *)",
      "Bash(bk artifacts list *)",
      "Bash(bk build list *)",
      "Bash(bk build view *)",
      "Bash(bk build watch *)",
      "Bash(bk cluster list *)",
      "Bash(bk cluster view *)",
      "Bash(bk config list *)",
      "Bash(bk config get *)",
      "Bash(bk job list *)",
      "Bash(bk job log *)",
      "Bash(bk organization list *)",
      "Bash(bk org list *)",
      "Bash(bk pipeline list *)",
      "Bash(bk pipeline view *)",
      "Bash(bk pipeline validate *)",
      "Bash(bk version *)",
      "Bash(bk whoami *)"
    ],
    "defaultMode": "plan"
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@latest --style=powerline"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "network": {},
    "filesystem": {
      "allowWrite": [
        ".git"
      ]
    }
  },
  "effortLevel": "high"
}
