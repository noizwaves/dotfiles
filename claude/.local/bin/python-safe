#!/usr/bin/env bash
set -euo pipefail

DOCKERFILE=$(cat <<'DOCKERFILE_EOF'
FROM python:3.12-slim
RUN pip install --no-cache-dir csvkit polars tabulate
DOCKERFILE_EOF
)

DOCKERFILE_SHA=$(printf '%s' "$DOCKERFILE" | shasum -a 256 | cut -c1-12)
IMAGE="python-safe:$DOCKERFILE_SHA"

# Detect host timezone (Python respects TZ env var)
# Priority: $TZ env var > /etc/localtime symlink > /etc/timezone file > UTC
if [[ -n "${TZ:-}" ]]; then
  HOST_TZ="$TZ"
elif [[ -L /etc/localtime ]]; then
  HOST_TZ=$(readlink /etc/localtime | sed 's|.*/zoneinfo/||')
elif [[ -f /etc/timezone ]]; then
  HOST_TZ=$(cat /etc/timezone)
else
  HOST_TZ="UTC"
fi

# Only attach TTY if stdin is a terminal
TTY_FLAG=""
[ -t 0 ] && TTY_FLAG="-t"

# Build image from embedded Dockerfile if not already cached
if ! docker image inspect "$IMAGE" &>/dev/null; then
  printf '%s' "$DOCKERFILE" | docker build -q -t "$IMAGE" -f - . >/dev/null
fi

exec docker run \
  --rm \
  -i $TTY_FLAG \
  --network=none \
  --read-only \
  --cap-drop=ALL \
  --security-opt=no-new-privileges \
  --tmpfs /tmp:rw,noexec,nosuid,size=64m \
  --pids-limit=256 \
  --memory=1g \
  --user "$(id -u):$(id -g)" \
  -e "TZ=$HOST_TZ" \
  -v "$PWD:$PWD:ro" \
  -w "$PWD" \
  "$IMAGE" \
  python "$@"
