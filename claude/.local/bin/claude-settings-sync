#!/usr/bin/env bash
# Keeps claude-personal and claude-work settings.json in sync for every top-level
# key except `env` and `enabledPlugins`. Invoked with no args — dispatches based
# on which of the two files are staged.
set -euo pipefail

PERSONAL="claude-personal/.claude/settings.json"
WORK="claude-work/.claude/settings.json"

merge() {
  local src=$1 dst=$2 tmp
  tmp=$(mktemp)
  jq --slurpfile d "$dst" '
    del(.env, .enabledPlugins)
    | .permissions.allow = ((.permissions.allow // []) | unique)
    | .permissions.ask   = ((.permissions.ask   // []) | unique)
    | ($d[0].env // null)            as $denv
    | ($d[0].enabledPlugins // null) as $dep
    | if $denv then .env = $denv else . end
    | if $dep  then .enabledPlugins = $dep else . end
  ' "$src" > "$tmp"
  mv "$tmp" "$dst"
}

shared_equal() {
  local projection='del(.env, .enabledPlugins)
    | .permissions.allow = ((.permissions.allow // []) | unique)
    | .permissions.ask   = ((.permissions.ask   // []) | unique)'
  diff -q <(jq "$projection" "$PERSONAL") <(jq "$projection" "$WORK") >/dev/null
}

mapfile -t staged < <(git diff --cached --name-only -- "$PERSONAL" "$WORK")

case ${#staged[@]} in
  0) exit 0 ;;
  1)
    if [[ ${staged[0]} == "$PERSONAL" ]]; then
      merge "$PERSONAL" "$WORK"
    else
      merge "$WORK" "$PERSONAL"
    fi
    ;;
  2)
    if shared_equal; then
      exit 0
    fi
    echo "claude-settings-sync: both settings.json files are staged and disagree on shared keys." >&2
    echo "Reconcile manually, then re-stage." >&2
    diff <(jq 'del(.env, .enabledPlugins)' "$PERSONAL") \
         <(jq 'del(.env, .enabledPlugins)' "$WORK") >&2 || true
    exit 1
    ;;
esac
