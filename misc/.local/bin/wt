#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: wt [--clone] [-b <branch>] <name>" >&2
  echo "" >&2
  echo "Create a git worktree at ~/workspace/<repo>--<name>" >&2
  echo "" >&2
  echo "Options:" >&2
  echo "  -b <branch>  Use an existing branch instead of creating an--<name>" >&2
  echo "  --clone      Create a full git clone instead of a worktree" >&2
  exit 1
}

branch=""
clone=false
name=""
while [[ $# -gt 0 ]]; do
  case $1 in
    -b)
      branch="${2:?"-b requires a branch name"}"
      shift 2
      ;;
    --clone)
      clone=true
      shift
      ;;
    -*)
      usage
      ;;
    *)
      if [[ -n "$name" ]]; then
        usage
      fi
      name="$1"
      shift
      ;;
  esac
done

if [[ -z "$name" ]]; then
  usage
fi
repo_root=$(git rev-parse --show-toplevel)
repo_name=$(basename "$repo_root")
worktree_path="$HOME/workspace/${repo_name}--${name}"

if [[ "$clone" == true ]]; then
  if [[ -n "$branch" ]]; then
    git clone --branch "$branch" "$repo_root" "$worktree_path"
  else
    git clone "$repo_root" "$worktree_path"
    git -C "$worktree_path" checkout -b "an--${name}"
  fi
  cp "$repo_root/.git/config" "$worktree_path/.git/config"
else
  if [[ -n "$branch" ]]; then
    git worktree add "$worktree_path" "$branch"
  else
    git worktree add "$worktree_path" -b "an--${name}"
  fi
fi

# Symlink .envrc if present
if [[ -f "$repo_root/.envrc" ]]; then
  ln -s "$repo_root/.envrc" "$worktree_path/.envrc"
  echo "Symlinked .envrc"
fi

# Symlink .claude/settings.local.json if present
if [[ -f "$repo_root/.claude/settings.local.json" ]]; then
  mkdir -p "$worktree_path/.claude"
  ln -s "$repo_root/.claude/settings.local.json" "$worktree_path/.claude/settings.local.json"
  echo "Symlinked .claude/settings.local.json"
fi

tmux-sessionizer "$worktree_path"
